# ============================================================
# 잽싸게(zebssak) 환경변수 — 값은 비워 둔 템플릿입니다.
# 로컬: 이 파일을 복사해 .env.local 로 저장 후 값을 채우세요.
# Vercel: 아래 "필수" 항목을 Dashboard → Settings → Environment Variables 에 넣은 뒤 Redeploy
# ============================================================

# --- 필수 (로그인·회원가입·DB) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=

# --- 선택 (역·열차·관리자) ---
SEOUL_METRO_API_KEY=
PUBLIC_DATA_API_KEY=
ADMIN_SECRET=

# --- .env.local 에만 있어도 됨 (코드에서 아직 미사용) ---
# INCHEON_METRO_API_KEY=
# KAKAO_MAP_API_KEY=
