# 로컬: 이 파일을 .env.local 로 복사해 사용
# Vercel: 아래 이름 그대로 Environment Variables 에 넣기 (.env.local 은 git 에 안 올라감)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서버 로그인 API — 아래 둘 중 하나 이상 (sb_secret 권장)
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

JWT_SECRET=
# 서울 지하철 Open API — 위치(OA-12601) / 도착(OA-12764) 키를 각각 넣기
SEOUL_METRO_POSITION_API_KEY=
SEOUL_METRO_ARRIVAL_API_KEY=
# 예전 단일 키 (둘 다 비었을 때만 폴백)
SEOUL_METRO_API_KEY=
PUBLIC_DATA_API_KEY=
ADMIN_SECRET=

# 심사 기간 PC 매칭 테스트 (Production Vercel에만 임시 설정, 심사 후 제거)
# MATCH_REVIEW_DEMO=true
# MATCH_REVIEW_DEMO_UNTIL=2026-07-18

# 로컬 개발용 실시간 검증 생략
# MATCH_DEV_SKIP_REALTIME=true
